#!/usr/bin/env python3
import subprocess
import os


def riverctl(*args):
    """Helper to run riverctl commands."""
    subprocess.run(["riverctl"] + list(args))


def spawn(command):
    """Helper to spawn background processes."""
    subprocess.Popen(command.split())


def spawn_unique(command):
    """Helper to spawn only once the processes at the start.
    Used for reload configuration."""
    process_name = command.split()[0]
    subprocess.run(["pkill", "-x", process_name], stderr=subprocess.DEVNULL)
    subprocess.Popen(
        command.split(), stderr=subprocess.DEVNULL, stdout=subprocess.DEVNULL
    )


def bindkey(keychord, key, command, params, mode="normal"):
    riverctl("map", mode, keychord, key, command, params)


# parameters & aliases
MOD = "Super"
TERM = "kitty"
FILEBROWSER = "thunar"
WEBBROWSER = "firefox"

RIVER_CONFIG_FOLDER = f"{os.path.expanduser('~')}/.config/river"

PADDING = 6
XCURSOR_THEME = "catppuccin-macchiato-light-cursors"
XCURSOR_SIZE = "24"


# --- 1. Startup Processes ---
# Env variables
# runtime_dir = os.environ.get("XDG_RUNTIME_DIR")
# riverctl("spawn", "notify-send", f"{runtime_dir}")
# os.environ["SSH_AUTH_SOCK"] = f"{runtime_dir}/ssh-agent.socket"
