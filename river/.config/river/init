# layout
spawn("riverctl default-layout wideriver")
spawn_unique(
    f"wideriver \
        --layout left \
        --stack dwindle \
        --ratio-master 0.6 \
        --count-master 1 \
        --inner-gaps {PADDING} \
        --outer-gaps {PADDING}"
)

spawn_unique("waybar")
spawn_unique(f"swaybg -i {RIVER_CONFIG_FOLDER}/wallpaper.png")
spawn_unique("mako")

# --- 2. Input Settings ---
TOUCHPAD = "*_Touchpad"
riverctl("keyboard-layout", "gb")
riverctl("input", TOUCHPAD, "events", "enabled")
riverctl("input", TOUCHPAD, "tap", "enabled")
riverctl("input", TOUCHPAD, "tap-button-map", "left-right-middle")
riverctl("input", TOUCHPAD, "natural-scroll", "enabled")

# --- 3. Keymaps ---
# river control
riverctl("map", "normal", f"{MOD}+Shift", "E", "exit")
riverctl("map", "normal", f"{MOD}+Shift", "C", "spawn", f"{RIVER_CONFIG_FOLDER}/init")

# layout control
riverctl("map", "normal", MOD, "J", "focus-view", "next")
riverctl("map", "normal", MOD, "K", "focus-view", "previous")
riverctl("map", "normal", MOD, "Tab", "zoom")
riverctl(
    "map",
    "normal",
    f"{MOD}+Shift",
    "H",
    "send-layout-cmd",
    "wideriver",
    "--ratio -0.05",
)
riverctl(
    "map",
    "normal",
    f"{MOD}+Shift",
    "L",
    "send-layout-cmd",
    "wideriver",
    "--ratio +0.05",
)

# apps
riverctl("map", "normal", MOD, "Return", "spawn", TERM)
riverctl("map", "normal", MOD, "E", "spawn", FILEBROWSER)
riverctl("map", "normal", MOD, "Space", "spawn", "rofi -show")
riverctl("map", "normal", MOD, "Q", "close")

# --- 4. Tags (1-9) ---
for i in range(1, 10):
    tags = 1 << (i - 1)
    riverctl("map", "normal", MOD, str(i), "set-focused-tags", str(tags))
    riverctl("map", "normal", f"{MOD}+Shift", str(i), "set-view-tags", str(tags))
    riverctl(
        "map", "normal", f"{MOD}+Control", str(i), "toggle-focused-tags", str(tags)
    )
    riverctl(
        "map", "normal", f"{MOD}+Shift+Control", str(i), "toggle-view-tags", str(tags)
    )
    all_tags = (1 << 32) - 1
    riverctl("map", "normal", MOD, "0", "set-focused-tags", str(all_tags))

# rules
riverctl("rule-add", "-app-id", "firefox", "tags", "4")
riverctl("default-attach-mode", "below")


# --- 5. Aesthetics ---
riverctl("border-width", "2")
riverctl("border-color-focused", "0x535d6c")
riverctl("border-color-unfocused", "0x2e3440")
riverctl("set-cursor-theme", XCURSOR_THEME, XCURSOR_SIZE)
